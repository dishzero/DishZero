{
    "tabWidth": 4,
    "semi": true,
    "singleQuote": true,
    "bracketSameLine": true,
    "printWidth": 120,
    "proseWrap": "always",
    "arrowParens": "always",
    "plugins": ["@ianvs/prettier-plugin-sort-imports"],
    "importOrderSafeSideEffects": ["\\.css$"],
    "importOrder": ["<THIRD_PARTY_MODULES>", "", "^@/", "", "^[./]"]
}
